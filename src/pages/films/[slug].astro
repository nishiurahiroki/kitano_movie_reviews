---
import GoogleAnalytics from "../../components/GoogleAnalytics.astro";
import { fetchPublishedReviews } from "../../lib/microcms";
import "../../styles/global.css";

export async function getStaticPaths() {
  const reviews = await fetchPublishedReviews();

  return reviews.map((r) => ({
    params: { slug: r.film.slug },
    props: { review: r },
  }));
}

const { review } = Astro.props;

const SITE_NAME = "徒然";
const siteUrl = import.meta.env.PUBLIC_SITE_URL?.replace(/\/$/, "");
const pageTitle = `${review.film.title} - 徒然レビュー`;
const plainBodyForMeta = String(review.body ?? "")
  .replace(/<br\s*\/?>/gi, "\n")
  .replace(/<\/p>\s*<p[^>]*>/gi, "\n\n")
  .replace(/<[^>]+>/g, "")
  .replace(/\s+/g, " ")
  .trim();
const pageDescription = plainBodyForMeta
  ? `${review.film.title}のレビュー。${plainBodyForMeta.slice(0, 110)}`
  : `${review.film.title}のレビュー。`;
const canonicalUrl = siteUrl ? `${siteUrl}/films/${review.film.slug}/` : undefined;
const ogImageUrl = siteUrl
  ? `${siteUrl}/og/films/${review.film.slug}.png`
  : `/og/films/${review.film.slug}.png`;
const yearMatch = String(review.film.releaseDate ?? "").match(/\d{4}/);
const releaseYear = yearMatch ? yearMatch[0] : "----";
const richBody = String(review.body ?? "").trim();
const shareUrl = canonicalUrl ?? `/films/${review.film.slug}/`;
const shareTitle = `${review.film.title} - 徒然レビュー`;
const shareMessage = `${review.film.title}のレビュー-徒然`;
const xShareUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(
  shareMessage,
)}&url=${encodeURIComponent(shareUrl)}`;
const threadsShareUrl = `https://www.threads.net/intent/post?text=${encodeURIComponent(
  `${shareMessage} ${shareUrl}`,
)}`;
const blueskyShareUrl = `https://bsky.app/intent/compose?text=${encodeURIComponent(
  `${shareMessage} ${shareUrl}`,
)}`;
const lineShareUrl = `https://social-plugins.line.me/lineit/share?url=${encodeURIComponent(
  shareUrl,
)}`;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Review",
  inLanguage: "ja-JP",
  name: `${review.film.title} レビュー`,
  reviewBody: plainBodyForMeta,
  itemReviewed: {
    "@type": "Movie",
    name: review.film.title,
    datePublished: releaseYear === "----" ? undefined : releaseYear,
  },
  publisher: {
    "@type": "Organization",
    name: SITE_NAME,
  },
};
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content="#0a111c" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <GoogleAnalytics />
  </head>
  <body class="page-film">
    <main class="container">
      <header class="header">
        <a class="back" href="/">← 作品一覧</a>
        <h1 class="film-title">{review.film.title}</h1>
        <p class="release-meta">
          <span class="meta-label">公開年</span>
          <span class="meta-separator">:</span>
          <span class="meta-year">{releaseYear}</span>
        </p>
      </header>

      <article class="review">
        <div class="review-body" set:html={richBody}></div>
      </article>

      <section
        class="post-tools"
        aria-label="記事の共有と移動"
        data-share-panel
        data-share-title={shareTitle}
        data-share-text={shareMessage}
        data-share-url={shareUrl}
      >
        <div class="share-panel">
          <p class="share-caption">この記事を共有</p>
          <div class="share-grid">
            <a
              class="share-icon-button"
              href={xShareUrl}
              target="_blank"
              rel="noreferrer noopener"
              aria-label="X で共有"
              title="X で共有"
            >
              <svg class="share-icon share-icon-x" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M18.901 1.153h3.68l-8.04 9.19L24 22.847h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.153h7.594l5.243 6.932zM17.61 20.644h2.039L6.486 3.24H4.298z"></path>
              </svg>
            </a>
            <a
              class="share-icon-button"
              href={threadsShareUrl}
              target="_blank"
              rel="noreferrer noopener"
              aria-label="Threads で共有"
              title="Threads で共有"
            >
              <svg class="share-icon share-icon-threads" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M18.02 8.78c-.08-1.82-.55-3.22-1.42-4.2C15.62 3.5 14.18 3 12.31 3 10.56 3 9.09 3.57 8.07 4.67c-.95 1.02-1.46 2.44-1.51 4.23-.06 1.93.35 3.51 1.23 4.68.98 1.31 2.48 2 4.45 2.05 1.64.04 3-.39 3.95-1.22.78-.68 1.18-1.57 1.17-2.59-.01-1.54-.98-2.71-2.77-3.35-.08-2.01-1.01-3.06-2.71-3.13-1.08-.04-1.99.32-2.61 1.04-.43.49-.67 1.14-.72 1.95h1.8c.05-.93.56-1.42 1.47-1.42.81 0 1.25.39 1.38 1.22-.62-.08-1.3-.06-2.04.06-2.04.32-3.11 1.39-3.04 3.03.04.8.39 1.46 1.03 1.9.58.39 1.32.61 2.15.61 1.08 0 1.96-.34 2.58-.99.45-.47.75-1.1.91-1.87.75.4 1.12.92 1.13 1.55.01.49-.19.94-.58 1.32-.72.7-2.08 1.15-3.75 1.11-1.92-.04-3.34-.65-4.26-1.81-.84-1.06-1.22-2.55-1.15-4.41.07-1.73.54-3.12 1.4-4.13.82-.96 2-1.43 3.55-1.43 1.67 0 2.98.5 3.9 1.5.84.91 1.31 2.2 1.39 3.84Zm-5.13 2.49c-.11 1.49-.72 2.24-1.83 2.24-.75 0-1.23-.35-1.26-.96-.05-.75.52-1.2 1.68-1.37.49-.08.96-.11 1.41-.08Z"></path>
              </svg>
            </a>
            <button
              class="share-icon-button"
              type="button"
              data-share-instagram
              aria-label="Instagram に共有"
              title="Instagram に共有"
            >
              <svg class="share-icon share-icon-instagram" viewBox="0 0 24 24" aria-hidden="true">
                <rect x="3.25" y="3.25" width="17.5" height="17.5" rx="5.25"></rect>
                <circle cx="12" cy="12" r="4.1"></circle>
                <circle cx="17.45" cy="6.55" r="1.15" class="share-icon-accent"></circle>
              </svg>
            </button>
            <a
              class="share-icon-button"
              href={blueskyShareUrl}
              target="_blank"
              rel="noreferrer noopener"
              aria-label="Bluesky で共有"
              title="Bluesky で共有"
            >
              <svg class="share-icon share-icon-bluesky" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 10.88c1.66-2.48 3.1-4.72 5.4-6.36 1.1-.78 2.88-1.37 2.88.67 0 .41-.24 3.44-.38 3.93-.48 1.71-2.24 2.15-3.81 2.42 2.74-.46 3.43 1.98 1.92 4.42-2.87 4.65-4.13-1.17-4.45-2.66-.06-.27-.08-.39-.08-.28 0-.11-.02.01-.08.28-.32 1.49-1.58 7.31-4.45 2.66-1.51-2.44-.82-4.88 1.92-4.42-1.57-.27-3.33-.71-3.81-2.42-.14-.49-.38-3.52-.38-3.93 0-2.04 1.78-1.45 2.88-.67 2.3 1.64 3.74 3.88 5.4 6.36Z"></path>
              </svg>
            </a>
            <a
              class="share-icon-button"
              href={lineShareUrl}
              target="_blank"
              rel="noreferrer noopener"
              aria-label="LINE で共有"
              title="LINE で共有"
            >
              <svg class="share-icon share-icon-line" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 3.2c-4.82 0-8.74 3.14-8.74 7s3.92 7 8.74 7c.66 0 1.31-.06 1.93-.18l4.23 2.34-.99-3.37c1.98-1.27 3.57-3.37 3.57-5.79 0-3.86-3.92-7-8.74-7Z"></path>
                <path class="share-icon-cutout" d="M8 8.45h1.29v4.1h2.23v1.2H8Zm4.18 0h1.29v5.3h-1.29Zm2.3 0h1.27l1.81 2.64V8.45h1.29v5.3h-1.2l-1.88-2.74v2.74h-1.29Z"></path>
              </svg>
            </a>
            <button
              class="share-icon-button"
              type="button"
              data-share-copy
              aria-label="リンクをコピー"
              title="リンクをコピー"
            >
              <svg class="share-icon share-icon-copy" viewBox="0 0 24 24" aria-hidden="true">
                <rect x="8" y="8" width="9" height="9" rx="1.8"></rect>
                <path d="M6.5 14.5H6A2 2 0 0 1 4 12.5V6a2 2 0 0 1 2-2h6.5a2 2 0 0 1 2 2v.5"></path>
              </svg>
            </button>
          </div>
          <p class="share-feedback" aria-live="polite" data-share-feedback></p>
        </div>

      </section>

      <footer class="article-footer" aria-label="記事ページフッター">
        <div class="article-footer-top">
          <a class="article-footer-button" href="/">← 作品一覧へ</a>
        </div>
        <nav class="article-footer-nav" aria-label="記事ページフッターリンク">
          <a href="/about/">サイト運営者について</a>
          <a href="/policy/">利用方針・免責事項</a>
        </nav>
        <p class="article-footer-copy">© {new Date().getFullYear()} 徒然</p>
      </footer>

    </main>
    <script is:inline>
      (() => {
        const panel = document.querySelector("[data-share-panel]");
        if (!panel) return;

        const instagramButton = panel.querySelector("[data-share-instagram]");
        const copyButton = panel.querySelector("[data-share-copy]");
        const feedback = panel.querySelector("[data-share-feedback]");
        const shareTitle = panel.getAttribute("data-share-title") ?? document.title;
        const shareText = panel.getAttribute("data-share-text") ?? "";
        const shareUrl = panel.getAttribute("data-share-url") ?? window.location.href;

        const setFeedback = (message) => {
          if (feedback) feedback.textContent = message;
        };

        const copyToClipboard = async () => {
          if (navigator.clipboard?.writeText) {
            await navigator.clipboard.writeText(shareUrl);
            return true;
          }

          return false;
        };

        instagramButton?.addEventListener("click", async () => {
          try {
            if (navigator.share) {
              await navigator.share({
                title: shareTitle,
                text: shareText,
                url: shareUrl,
              });
              setFeedback("共有シートを開きました。Instagram など共有先を選べます。");
              return;
            }

            const copied = await copyToClipboard();
            setFeedback(
              copied
                ? "Instagram の直接共有に未対応のため、記事URLをコピーしました。"
                : "Instagram の直接共有に未対応のため、URL を手動で共有してください。",
            );
          } catch (error) {
            if (error instanceof DOMException && error.name === "AbortError") {
              setFeedback("共有はキャンセルされました。");
              return;
            }

            const copied = await copyToClipboard();
            setFeedback(
              copied
                ? "共有に失敗したため、記事URLをコピーしました。"
                : "共有に失敗しました。URL を手動で共有してください。",
            );
          }
        });

        copyButton?.addEventListener("click", async () => {
          const copied = await copyToClipboard();
          setFeedback(
            copied
              ? "記事URLをコピーしました。"
              : "クリップボードにアクセスできませんでした。",
          );
        });
      })();
    </script>
  </body>
</html>
