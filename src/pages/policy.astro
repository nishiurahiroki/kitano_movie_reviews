---
import GoogleAnalytics from '../components/GoogleAnalytics.astro'
import '../styles/global.css'

const pageTitle = '利用方針・免責事項 - 徒然'
const pageDescription = '北野武映画レビューサイト「徒然」の利用方針と免責事項。'
const siteUrl = import.meta.env.PUBLIC_SITE_URL?.replace(/\/$/, "")
const canonicalUrl = siteUrl ? `${siteUrl}/policy/` : undefined
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content="#0a111c" />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
    <GoogleAnalytics />
  </head>
  <body class="page-policy">
    <main class="container policy-container">
      <header class="header policy-header">
        <a class="back" href="/">← 作品一覧</a>
        <h1 class="policy-title">利用方針・免責事項</h1>
        <p class="policy-lead">
          このページは、当サイトで公開しているレビューの取り扱い方針と免責事項を示すものです。
        </p>
      </header>

      <section class="policy-list" aria-label="利用方針一覧">
        <article class="policy-item">
          <h2>1. コンテンツの性質</h2>
          <p>
            当サイトのレビューは、運営者個人の感想・解釈に基づくものであり、作品内容の正確性や完全性を保証するものではありません。
          </p>
        </article>

        <article class="policy-item">
          <h2>2. ネタバレについて</h2>
          <p>
            当サイトはネタバレを含みます。閲覧により生じたいかなる不利益についても、運営者は責任を負いません。
          </p>
        </article>

        <article class="policy-item">
          <h2>3. 著作権・知的財産権</h2>
          <p>
            映画作品に関する著作権その他の知的財産権は、各権利者に帰属します。当サイト掲載文の無断転載・複製はご遠慮ください。
          </p>
        </article>

        <article class="policy-item">
          <h2>4. 外部リンク</h2>
          <p>
            当サイトからリンクしている外部サイトの内容・サービスについて、運営者は責任を負いません。リンク先の利用条件をご確認ください。
          </p>
        </article>

        <article class="policy-item">
          <h2>5. 方針の更新</h2>
          <p>
            本方針は必要に応じて予告なく更新することがあります。更新後は当ページに掲載した時点で効力を生じるものとします。
          </p>
        </article>
      </section>
    </main>
  </body>
</html>
