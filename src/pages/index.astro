---
import { fetchAllFilsm, fetchPublishedReviews } from '../lib/microcms'
import '../styles/global.css'

const SITE_NAME = "徒然"
const siteUrl = import.meta.env.PUBLIC_SITE_URL?.replace(/\/$/, "")
const pageTitle = `${SITE_NAME} - 北野武映画レビュー`
const pageDescription = "北野武監督作品のレビューを淡々と掲載していくサイト。公開済みレビュー作品のみ閲覧できます。"
const canonicalUrl = siteUrl ? `${siteUrl}/` : undefined

const films = await fetchAllFilsm()
const reviews = await fetchPublishedReviews()

const reviewedFilmIds = new Set(reviews.map(r => r.film.id))

const sorted = [...films].sort((a, b) => (a.releaseDate < b.releaseDate ? -1 : 1))
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content="#0a111c" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
  </head>
  <body class="page-home">
    <main class="container">
      <header class="header">
        <h1 class="site-title">{SITE_NAME}</h1>
      </header>

      <section class="description" aria-label="このサイトについて">
        <p class="description-text">
          お越しいただきありがとうございます。北野武監督作品のレビューを淡々と載せて行きます。
        </p>
        <p class="description-text">
          ネタバレ前提となっております。ご了承頂けますと幸いです。
        </p>
        <p class="description-text">
          布教の目的もありますが、北野映画が好きでお越しいただいた方に、本サイトのレビューを通して、共感や作品の余韻を味わっていただく使い方をして頂けると幸いです。
        </p>
      </section>

      <ul class="film-list">
        {sorted.map((f) => {
          const hasReview = reviewedFilmIds.has(f.id);
          return (
            <li class="film-item">
              {hasReview ? (
                <a class="film-link" href={`/films/${f.slug}/`}>
                  {f.title}
                </a>
              ) : (
                <span class="film-disabled">
                  {f.title}
                  <span class="badge">準備中</span>
                </span>
              )}
            </li>
          );
        })}
      </ul>

      <footer class="site-footer" aria-label="フッター">
        <nav class="footer-nav" aria-label="フッターリンク">
          <a href="/about/">サイト運営者について</a>
          <a href="/policy/">利用方針・免責事項</a>
        </nav>
        <p class="copyright">© {new Date().getFullYear()} 徒然</p>
      </footer>
    </main>
  </body>
</html>
